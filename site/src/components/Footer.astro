---
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="brand"><span>MEM</span><span class="brand-accent">9</span></p>
    <div class="footer-links">
      <a href="https://github.com/qiffang/mnemos" target="_blank" rel="noopener">GitHub</a>
      <span class="sep">/</span>
      <a href="https://github.com/qiffang/mnemos/blob/main/LICENSE" target="_blank" rel="noopener">Apache-2.0</a>
      <span class="sep">/</span>
      <a href="https://github.com/qiffang/mnemos/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener">Contributing</a>
    </div>
    <p class="copyright">
      mem9.ai. Unlimited memory infrastructure for AI agents.
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: 4rem 0 2.5rem;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  .brand-accent {
    color: var(--accent);
  }

  .footer-links {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .sep {
    color: var(--text-dim);
  }
  .copyright {
    font-size: 0.85rem;
    color: var(--text-dim);
  }
</style>
